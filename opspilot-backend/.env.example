# --- AWS ---------------------------------------------------------------
# Picked up automatically by boto3 — do not read these in app code,
# just make sure they're set in the environment.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# The EC2 instance the agent investigates (Step 6 of the setup guide).
# Never hardcode this in code — it changes if you relaunch the instance.
OPSPILOT_EC2_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx

# --- LLM provider (free-tier only) --------------------------------------
# Which provider to try first. Fallback order is always groq -> gemini -> nvidia.
OPSPILOT_LLM_PRIMARY_PROVIDER=groq

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- App -----------------------------------------------------------------
OPSPILOT_APP_ENV=local
OPSPILOT_CORS_ORIGINS=http://localhost:3000

# --- Auth (Section 3.5) ---------------------------------------------------
# Must exactly match AUTH_SHARED_SECRET in opspilot-frontend/.env.local —
# used to verify the short-lived bearer token NextAuth mints on sign-in.
# Generate with: openssl rand -base64 32
AUTH_SHARED_SECRET=replace-with-the-same-value-as-frontend-AUTH_SHARED_SECRET

# Optional: restrict accepted sessions to this exact email (defense in
# depth on top of the frontend's own single ADMIN_EMAIL check). Leave
# blank to accept any validly-signed token.
ADMIN_EMAIL=admin@example.com

# --- MCP server access token (Section 3.6) ---------------------------------
# Generate this from Settings -> MCP Access in the dashboard (shown once —
# copy it immediately), then set it here so `python -m app.mcp.server`
# picks it up locally. Stdio JSON-RPC has no per-request Authorization
# header, so this env var IS the credential — required on every tool call,
# even for local testing (checked fresh each call, so revoking takes effect
# immediately). Leave blank until you've generated a token; every MCP tool
# call is rejected until it's set to a valid, non-revoked token.
OPSPILOT_MCP_TOKEN=
