# Where the FastAPI backend is reachable from the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Auth (Section 3.5) -------------------------------------------------
# NextAuth's own config. Generate a secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-value

# Single admin-style login (email/password, no OAuth, single account scope).
# ADMIN_PASSWORD_HASH must be a bcrypt hash, never a plaintext password.
# Generate one with:
#   node -e "require('bcryptjs').hash(process.argv[1], 10).then(console.log)" "your-password-here"
# IMPORTANT: bcrypt hashes contain literal `$` characters, and Next.js's
# .env loader treats `$` as variable-expansion syntax — escape every `$`
# as `\$` in this file or the hash will be silently truncated.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=\$2b\$10\$replace-with-a-bcrypt-hash-dollars-escaped

# Shared secret used to sign/verify the short-lived API bearer token that
# lets FastAPI independently validate the session (see opspilot-backend
# app/core/security.py). MUST match AUTH_SHARED_SECRET in opspilot-backend/.env.
AUTH_SHARED_SECRET=replace-with-another-long-random-value
